# PrintBot AI - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI (Required for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# E-commerce Platform APIs
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_STORE_URL=your-store.myshopify.com

# Payment Processing
STRIPE_API_KEY=your_stripe_api_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Fulfillment Providers (Add at least one)
PRINTFUL_API_KEY=your_printful_api_key
PRINTIFY_API_KEY=your_printify_api_key
GELATO_API_KEY=your_gelato_api_key
GOOTEN_API_KEY=your_gooten_api_key

# Social Media APIs (Add for auto-posting)
INSTAGRAM_API_KEY_1=your_instagram_key_1
INSTAGRAM_API_KEY_2=your_instagram_key_2
INSTAGRAM_API_KEY_3=your_instagram_key_3

TIKTOK_API_KEY_1=your_tiktok_key_1
TIKTOK_API_KEY_2=your_tiktok_key_2
TIKTOK_API_KEY_3=your_tiktok_key_3

PINTEREST_API_KEY_1=your_pinterest_key_1
PINTEREST_API_KEY_2=your_pinterest_key_2
PINTEREST_API_KEY_3=your_pinterest_key_3

# Email Service (SendGrid recommended)
SENDGRID_API_KEY=your_sendgrid_api_key

# Optional: Sentry for error tracking
SENTRY_DSN=your_sentry_dsn
