# PrintBot AI - Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED - These are needed for the system to function
# ============================================================================

# Shopify Custom App (Required for product listing and order management)
# Follow SHOPIFY_SETUP.md to create a Custom App and get your permanent access token.
# The token starts with shpat_ and never expires.
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_custom_app_token_here

# Printful (Required for fulfillment)
PRINTFUL_API_KEY=your_printful_api_key
PRINTFUL_STORE_ID=your_store_id

# OpenAI (Required for design generation)
OPENAI_API_KEY=sk-your_openai_api_key

# Design Auto-Approval (REQUIRED for products to appear in your Shopify store)
# When false (default): designs are generated but sit as "pending" — nothing reaches Shopify.
# Set to true to enable the full automation pipeline: trend → design → approve → Shopify product.
DESIGN_AUTO_APPROVE=true

# ============================================================================
# OPTIONAL - These enhance functionality but aren't required
# ============================================================================

# Social Media - Instagram (3 accounts supported)
INSTAGRAM_USERNAME_0=your_main_account
INSTAGRAM_PASSWORD_0=your_password
INSTAGRAM_API_KEY_0=optional_api_key

INSTAGRAM_USERNAME_1=backup_account_1
INSTAGRAM_PASSWORD_1=password_1
INSTAGRAM_API_KEY_1=

INSTAGRAM_USERNAME_2=backup_account_2
INSTAGRAM_PASSWORD_2=password_2
INSTAGRAM_API_KEY_2=

# Social Media - TikTok (3 accounts supported)
TIKTOK_USERNAME_0=your_main_account
TIKTOK_PASSWORD_0=your_password
TIKTOK_API_KEY_0=

TIKTOK_USERNAME_1=backup_account_1
TIKTOK_PASSWORD_1=password_1
TIKTOK_API_KEY_1=

TIKTOK_USERNAME_2=backup_account_2
TIKTOK_PASSWORD_2=password_2
TIKTOK_API_KEY_2=

# Email Notifications (for order tracking)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=your_email@gmail.com

# Emergency Contact (for dead man's switch)
EMERGENCY_CONTACT=your_phone_number

# Cloud Backup (Google Drive or Dropbox token)
BACKUP_CLOUD_TOKEN=your_cloud_storage_token

# ============================================================================
# ADVANCED - Only change if you know what you're doing
# ============================================================================

# Dead Man's Switch Interval (hours)
CHECK_IN_INTERVAL=24

# Backup Interval (seconds - default weekly)
BACKUP_INTERVAL=604800

# Rate Limiting Strategy (exponential or linear)
RATE_LIMIT_BACKOFF=exponential

# Maximum API Retries
MAX_RETRIES=5

# Base Delay for Rate Limiting (seconds)
BASE_DELAY=60
